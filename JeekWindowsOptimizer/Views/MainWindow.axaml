<Window
    x:Class="JeekWindowsOptimizer.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:Jeek.Avalonia.Localization"
    xmlns:local="using:JeekWindowsOptimizer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Jeek Windows Optimizer"
    Width="900"
    Height="2000"
    d:DesignHeight="450"
    d:DesignWidth="900"
    x:DataType="local:MainViewModel"
    Icon="/Assets/App.ico"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource Win11ChromeBackgroundBrush}"
    mc:Ignorable="d">

    <!-- Win11 Settings–like: flat section headers (Expander) + card rows -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="Win11ChromeBackgroundBrush" Color="#FF1C1C1C" />
                    <SolidColorBrush x:Key="Win11SettingsCardBackgroundBrush" Color="#FF2B2B2B" />
                    <SolidColorBrush x:Key="Win11SettingsCardBorderBrush" Color="#FF3A3A3A" />
                    <SolidColorBrush x:Key="Win11SecondaryTextBrush" Color="#FFA6A6A6" />

                    <SolidColorBrush x:Key="AccentButtonForeground" Color="#FF000000" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FF000000" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FF000000" />
                    <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#FF717171" />

                    <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPointerOver" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPressed" Color="#22000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundDisabled" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPointerOver" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPressed" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushDisabled" Color="#00000000" />

                    <SolidColorBrush x:Key="ExpanderChevronBackground" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBackgroundPointerOver" Color="#14FFFFFF" />
                    <SolidColorBrush x:Key="ExpanderChevronBackgroundPressed" Color="#22000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBackgroundDisabled" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrush" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrushPointerOver" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrushPressed" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrushDisabled" Color="#00000000" />

                    <SolidColorBrush x:Key="ExpanderContentBackground" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="#00000000" />

                    <Thickness x:Key="ExpanderHeaderBorderThickness">0</Thickness>
                    <Thickness x:Key="ExpanderContentDownBorderThickness">0</Thickness>
                    <Thickness x:Key="ExpanderContentPadding">0,16,0,4</Thickness>
                    <Thickness x:Key="ExpanderHeaderPadding">0</Thickness>
                    <x:Double x:Key="ExpanderMinHeight">44</x:Double>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="Win11ChromeBackgroundBrush" Color="#FFF3F3F3" />
                    <SolidColorBrush x:Key="Win11SettingsCardBackgroundBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="Win11SettingsCardBorderBrush" Color="#FFE5E5E5" />
                    <SolidColorBrush x:Key="Win11SecondaryTextBrush" Color="#FF666666" />

                    <SolidColorBrush x:Key="AccentButtonForeground" Color="#FF000000" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FF000000" />
                    <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FF000000" />
                    <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#FF717171" />

                    <!-- 浅色主题下 accent 按钮：Win11 设置式白底描边次级按钮 -->
                    <SolidColorBrush x:Key="AccentButtonBackground" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#FFF9F9F9" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#FFF0F0F0" />
                    <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#FFF8F8F8" />

                    <SolidColorBrush x:Key="AccentButtonBorderBrush" Color="#FFDADADA" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="#FFBFBFBF" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushPressed" Color="#FFB3B3B3" />
                    <SolidColorBrush x:Key="AccentButtonBorderBrushDisabled" Color="#FFDADADA" />

                    <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPointerOver" Color="#08000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPressed" Color="#14000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundDisabled" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPointerOver" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPressed" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushDisabled" Color="#00000000" />

                    <SolidColorBrush x:Key="ExpanderChevronBackground" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBackgroundPointerOver" Color="#09000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBackgroundPressed" Color="#12000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBackgroundDisabled" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrush" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrushPointerOver" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrushPressed" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderChevronBorderBrushDisabled" Color="#00000000" />

                    <SolidColorBrush x:Key="ExpanderContentBackground" Color="#00000000" />
                    <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="#00000000" />

                    <Thickness x:Key="ExpanderHeaderBorderThickness">0</Thickness>
                    <Thickness x:Key="ExpanderContentDownBorderThickness">0</Thickness>
                    <Thickness x:Key="ExpanderContentPadding">0,16,0,4</Thickness>
                    <Thickness x:Key="ExpanderHeaderPadding">0</Thickness>
                    <x:Double x:Key="ExpanderMinHeight">44</x:Double>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Design.DataContext>
        <!--
            This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
        -->
        <local:MainViewModel />
    </Design.DataContext>

    <Grid
        Margin="24,20"
        ColumnDefinitions="*"
        RowDefinitions="Auto Auto *">
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,10"
            Orientation="Vertical"
            Spacing="10">
            <StackPanel.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Command="{Binding SwitchToEnglishCommand}"
                        GroupName="Language"
                        Header="{l:Localize en}"
                        IsChecked="{Binding IsEnglishMenuChecked, Mode=OneWay}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding SwitchToChineseCommand}"
                        GroupName="Language"
                        Header="{l:Localize zh}"
                        IsChecked="{Binding IsChineseMenuChecked, Mode=OneWay}"
                        ToggleType="Radio" />
                    <Separator />
                    <MenuItem
                        Command="{Binding SwitchToLightThemeCommand}"
                        GroupName="Theme"
                        Header="{l:Localize ThemeLight}"
                        IsChecked="{Binding IsLightThemeMenuChecked, Mode=OneWay}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding SwitchToDarkThemeCommand}"
                        GroupName="Theme"
                        Header="{l:Localize ThemeDark}"
                        IsChecked="{Binding IsDarkThemeMenuChecked, Mode=OneWay}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding SwitchToSystemThemeCommand}"
                        GroupName="Theme"
                        Header="{l:Localize ThemeSystem}"
                        IsChecked="{Binding IsSystemThemeMenuChecked, Mode=OneWay}"
                        ToggleType="Radio" />
                </ContextMenu>
            </StackPanel.ContextMenu>

            <ProgressBar
                Height="20"
                HorizontalAlignment="Stretch"
                IsIndeterminate="True"
                IsVisible="{Binding IsBusy}" />
            <Button
                Padding="20,12"
                Classes="accent"
                HorizontalAlignment="Center"
                Command="{Binding OptimizeCheckedItems}"
                Content="{l:Localize OptimizeSelectedItems}"
                CornerRadius="6"
                FontSize="18"
                FontWeight="SemiBold"
                IsVisible="{Binding CanShowOptimizeButton}" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="14"
                Foreground="{DynamicResource Win11SecondaryTextBrush}"
                Text="{Binding StatusMessage}" />
        </StackPanel>

        <TabStrip
            Grid.Row="1"
            Margin="0,4,0,8"
            SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="{Binding OptimizingTabHeader}" />
            <TabItem Header="{Binding AntivirusTabHeader}" />
            <TabItem Header="{Binding PersonalTabHeader}" />
            <TabItem Header="{Binding ToolsTabHeader}" />
        </TabStrip>

        <ScrollViewer
            Grid.Row="2"
            IsVisible="{Binding IsOptimizationTabSelected}"
            VerticalAlignment="Stretch"
            VerticalScrollBarVisibility="Visible">

            <!--  Groups  -->
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Expander HorizontalAlignment="Stretch" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Text="{Binding Name}" />
                            </Expander.Header>

                            <!--  Items  -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border
                                            Padding="14,12"
                                            Background="{DynamicResource Win11SettingsCardBackgroundBrush}"
                                            BorderBrush="{DynamicResource Win11SettingsCardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            PointerPressed="InputElement_OnPointerPressed">

                                            <Grid ColumnDefinitions="* Auto">
                                                <StackPanel Orientation="Vertical" Spacing="6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <CheckBox IsChecked="{Binding IsChecked}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="17"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Name}" />
                                                    </StackPanel>
                                                    <TextBlock
                                                        Margin="0,0,20,0"
                                                        FontSize="14"
                                                        Foreground="{DynamicResource Win11SecondaryTextBrush}"
                                                        Text="{Binding Description}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Spacing="12">
                                                    <Grid VerticalAlignment="Center">
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="14"
                                                            IsVisible="{Binding IsOptimized}"
                                                            Text="{l:Localize Optimized}" />
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="14"
                                                            IsVisible="{Binding !IsOptimized}"
                                                            Text="{l:Localize NotOptimized}" />
                                                    </Grid>
                                                    <ToggleSwitch
                                                        VerticalAlignment="Center"
                                                        OffContent=""
                                                        OnContent=""
                                                        IsChecked="{Binding IsOptimized, Mode=OneWay}"
                                                        IsCheckedChanged="ToggleButton_OnIsCheckedChanged" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Expander>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ScrollViewer
            Grid.Row="2"
            IsVisible="{Binding IsToolsTabSelected}"
            VerticalAlignment="Stretch"
            VerticalScrollBarVisibility="Visible">

            <!--  Tool Groups  -->
            <ItemsControl ItemsSource="{Binding ToolGroups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Expander HorizontalAlignment="Stretch" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Text="{Binding Name}" />
                            </Expander.Header>

                            <!--  Tools  -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border
                                            Padding="14,12"
                                            Background="{DynamicResource Win11SettingsCardBackgroundBrush}"
                                            BorderBrush="{DynamicResource Win11SettingsCardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">

                                            <Grid ColumnDefinitions="* Auto">
                                                <StackPanel Orientation="Vertical" Spacing="6">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="17"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Margin="0,0,20,0"
                                                        FontSize="14"
                                                        Foreground="{DynamicResource Win11SecondaryTextBrush}"
                                                        Text="{Binding Description}"
                                                        TextWrapping="Wrap" />
                                                    <TextBlock
                                                        Margin="0,0,20,0"
                                                        FontSize="13"
                                                        Foreground="{DynamicResource Win11SecondaryTextBrush}"
                                                        IsVisible="{Binding HasDisplayStatus}"
                                                        Text="{Binding DisplayStatus}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button
                                                    Grid.Column="1"
                                                    Padding="16,8"
                                                    Classes="accent"
                                                    HorizontalAlignment="Right"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Command="{Binding RunCommand}"
                                                    Content="{l:Localize RunTool}"
                                                    CornerRadius="6" />
                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Expander>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>

</Window>
